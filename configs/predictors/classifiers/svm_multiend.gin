predictor/gin.singleton.constructor = @SvmClassifier
predictor = @predictor/gin.singleton()

SvmClassifier.params = {
    'C': 3,
    'kernel': 'rbf',
    'gamma': 'scale',
    }

SvmClassifier.multi_endpoint = True

# Include hyperparameter optimization config
include 'configs/predictors/classifiers/optimization/svm_hyperparams.gin'
